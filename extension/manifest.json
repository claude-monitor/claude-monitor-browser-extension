{
  "manifest_version": 3,
  "name": "Claude Usage Monitor: Fable, Session & Weekly Limits",
  "short_name": "Claude Usage",
  "version": "1.10.0",
  "description": "The first tracker for Claude's Fable weekly cap. Session & weekly limits, reset times, and 80%/95% alerts — in your toolbar.",
  "author": "Digital Advanced Solutions",
  "minimum_chrome_version": "116",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": [
    "https://claude.ai/api/organizations",
    "https://claude.ai/api/organizations/*/usage",
    "https://claude.ai/api/organizations/*/prepaid/credits",
    "https://claude.ai/api/organizations/*/overage_spend_limit",
    "https://claude.ai/v1/code/routines/run-budget"
  ],
  "homepage_url": "https://claude-monitor.com/",
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage Monitor",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
